# =============================================
# 노션 자동 발행 시스템 - 환경변수 설정
# 이 파일을 복사해서 .env 로 저장 후 값을 채우세요
# =============================================

# [1] 노션 (Notion)
# https://www.notion.so/my-integrations 에서 발급
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 발행 관리용 데이터베이스 ID
# URL: https://notion.so/xxxxxxxx?v=... 에서 첫번째 xxxxxxxx 부분
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# [2] 네이버 블로그
# 일반 네이버 로그인 아이디/비밀번호 사용 (API 없이 브라우저 자동화)
NAVER_ID=your_naver_id
NAVER_PW=your_naver_password
NAVER_BLOG_ID=your_blog_id  # 블로그 주소의 아이디 부분

# [3] 아임웹 (Imweb)
# 아임웹 관리자 > 내 정보 > API 키 관리
IMWEB_API_KEY=your_imweb_api_key
IMWEB_API_SECRET=your_imweb_api_secret
# 게시판 코드: 관리자 > 콘텐츠 > 게시판 > 해당 게시판 코드
IMWEB_BOARD_CODE=your_board_code

# [4] 페이스북 (Facebook)
# Meta 개발자 > 내 앱 > 페이지 액세스 토큰
# 발급 방법: https://developers.facebook.com/tools/explorer/
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_ACCESS_TOKEN=your_page_access_token

# [5] 스티비 (Stibee)
# 스티비 설정 > API 키
STIBEE_API_KEY=your_stibee_api_key
# 주소록 ID: 스티비 > 주소록 > 해당 주소록 URL의 숫자
STIBEE_ADDRESS_BOOK_ID=12345
STIBEE_SENDER_EMAIL=sender@yourcompany.com
STIBEE_SENDER_NAME=회사이름
